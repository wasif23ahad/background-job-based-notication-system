# Django
# Generate a secure key: https://djecrety.ir/
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_SETTINGS_MODULE=config.settings.local
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
TIME_ZONE=UTC
LOG_LEVEL=INFO
PORT=10000
WEB_CONCURRENCY=2
WEB_TIMEOUT=120

# PostgreSQL (preferred)
# Neon dashboard (connection details): https://console.neon.tech/
# Example local Docker URL:
# postgresql://postgres:postgres@db:5432/webbly_notifications
DATABASE_URL=postgresql://postgres:postgres@db:5432/webbly_notifications

# Provided Neon URL example (replace password/user/db as needed):
# postgresql://neondb_owner:<password>@ep-xxxxxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Redis (Celery broker + result backend)
# Upstash Redis: https://console.upstash.com/redis
# Redis Cloud: https://redis.com/redis-enterprise-cloud/overview/
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}
CELERY_REDIS_SSL_CERT_REQS=required
CELERY_TIMEZONE=UTC
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=False
RUN_CELERY_WORKER=false
CELERY_LOG_LEVEL=info
CELERY_BROKER_CONNECTION_TIMEOUT=3
CELERY_REDIS_SOCKET_CONNECT_TIMEOUT=2
CELERY_REDIS_SOCKET_TIMEOUT=2

# Upstash REST credentials (optional; useful for HTTP Redis operations)
# Upstash console: https://console.upstash.com/redis
# IMPORTANT: Celery broker does NOT use REST_URL; it requires REDIS_URL as redis:// or rediss://
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# JWT lifetimes (seconds)
# Docs: https://django-rest-framework-simplejwt.readthedocs.io/
JWT_ACCESS_TOKEN_LIFETIME=900
JWT_REFRESH_TOKEN_LIFETIME=86400

# Notification simulation
# If this keyword appears in title/message, delivery will fail intentionally.
NOTIFICATION_FAILURE_KEYWORD=__FAIL__

# Docker PostgreSQL container defaults
POSTGRES_DB=webbly_notifications
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
